---
import Base from '../../layouts/Base.astro';
import record from '../../data/record.json';
import { sevClass, type Event } from '../../lib/format';

export function getStaticPaths() {
  return ((record.events ?? []) as Event[]).map((e) => ({ params: { id: e.id }, props: { ev: e } }));
}
const { ev } = Astro.props as { ev: Event };
---

<Base title={`Annals — ${ev.diff_type}`}>
  <p><a href={`/target/${ev.target_id}`}>← {ev.target_id}</a></p>
  <h1><span class={`badge ${sevClass(ev.severity)}`}>{ev.severity}</span> {ev.diff_type}</h1>
  <p class="muted">Detected {ev.detected_at} · differ layer {ev.layer}</p>

  <h2>Evidence</h2>
  <pre>{JSON.stringify(ev.evidence, null, 2)}</pre>

  <h2>Attested observations</h2>
  <p>
    from <code>{ev.from_hash ?? '(first observation)'}</code><br />
    to <code>{ev.to_hash}</code>
  </p>
  <p class="muted">
    That content A was observed at one time and content B at another is cryptographically attested and
    offline-verifiable (download the proof bundle for either observation). This classification is Annals'
    best-effort, human-reviewable interpretation — not a verified fact.
  </p>

  <h2>Permalink</h2>
  <p><code>{ev.id}</code></p>

  <p><a href="/verify">→ Verify a downloaded proof bundle in your browser</a> (offline, trusting no one).</p>
</Base>
