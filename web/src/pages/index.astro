---
import Base from '../layouts/Base.astro';
import record from '../data/record.json';
import { sevClass, summarize, type Event } from '../lib/format';

const events = (record.events ?? []) as Event[];
const targets = record.targets ?? [];
---

<Base title="Druid — the public record">
  <section class="hero">
    <h1>What the government's environmental data said — and how it is being changed.</h1>
    <p>
      An immutable, provable record over a curated set of high-value targets. Every observation is
      cryptographically attested and independently verifiable offline; every change below is classified.
    </p>
    <p>
      <a href="/feed.xml">Subscribe (RSS) to all changes →</a>
      &nbsp;·&nbsp;
      <a href="/verify">Verify a proof bundle in your browser →</a>
      &nbsp;·&nbsp;
      <a href="/overlay">Federated overlay (attested vs archived) →</a>
    </p>
  </section>

  <section>
    <h2>Recent changes</h2>
    {events.length === 0 && <p class="muted">No changes recorded yet.</p>}
    {events.length > 0 && (
      <input id="search" type="search" placeholder="Filter changes (target, type, severity, value)…" autocomplete="off" />
    )}
    <ul class="events">
      {events.slice(0, 200).map((ev) => (
        <li
          id={`event-${ev.id.slice(0, 16)}`}
          data-search={`${ev.diff_type} ${ev.target_id} ${ev.severity} ${summarize(ev)}`.toLowerCase()}
        >
          <span class={`badge ${sevClass(ev.severity)}`}>{ev.severity}</span>
          <a class="type" href={`/event/${ev.id}`}>{ev.diff_type}</a>
          <span class="summary"><a href={`/target/${ev.target_id}`}>{ev.target_id}</a> — {summarize(ev)}</span>
          <time>{ev.detected_at}</time>
        </li>
      ))}
    </ul>
    <p id="no-results" class="muted" hidden>No changes match that filter.</p>
    <style>
      #search { width: 100%; margin: 4px 0 14px; padding: 9px 12px; border-radius: 8px;
        border: 1px solid var(--line); background: #0b0e12; color: var(--ink); font: inherit; }
      #search:focus { outline: none; border-color: var(--accent); }
    </style>
    <script is:inline>
      (() => {
        const input = document.getElementById('search');
        if (!input) return;
        const items = Array.from(document.querySelectorAll('ul.events > li'));
        const none = document.getElementById('no-results');
        input.addEventListener('input', () => {
          const q = input.value.trim().toLowerCase();
          let shown = 0;
          for (const li of items) {
            const hit = !q || (li.dataset.search || '').includes(q);
            li.hidden = !hit;
            if (hit) shown++;
          }
          if (none) none.hidden = shown > 0;
        });
      })();
    </script>
  </section>

  <section>
    <h2>Targets</h2>
    <div class="targets">
      {targets.map((t: any) => (
        <a class="card" href={`/target/${t.id}`}>
          <h3>{t.title}</h3>
          <p class="url">{t.url}</p>
          <p class="stat">{t.observations.length} observations · {t.events.length} changes · {t.kind}</p>
        </a>
      ))}
    </div>
  </section>
</Base>
