---
import Base from '../layouts/Base.astro';
import overlay from '../data/overlay.json';

const resources = (overlay.resources ?? []) as any[];
const sources = (overlay.sources ?? []) as string[];
const attested = overlay.attested_count ?? 0;
---

<Base title="Verderer — federated overlay">
  <section class="hero">
    <h1>Federated overlay index</h1>
    <p>
      The volunteer rescue ecosystem has archived far more than Verderer observes. This index
      cross-references those third-party archives ({sources.join(', ') || 'none'}) against
      Verderer's own attested record. A <strong>verderer-attested</strong> resource carries a
      self-verifying proof bundle — exactly-these-bytes, offline-verifiable, trusting no one.
      A third-party-only copy is a real archive, but there is nothing to <em>prove</em> about
      its bytes, so it shows no badge.
    </p>
    <p class="muted">{attested} of {resources.length} resources are Verderer-attested.</p>
  </section>

  <section>
    {resources.length > 0 && (
      <input id="search" type="search" placeholder="Filter resources (URL, source, attested)…" autocomplete="off" />
    )}
    <ul class="resources">
      {resources.map((r: any) => (
        <li data-search={`${r.url} ${r.attested ? 'attested verderer-attested' : 'unverified'} ${(r.external ?? []).map((e: any) => e.source).join(' ')}`.toLowerCase()}>
          <div class="row">
            {r.attested
              ? <span class="badge att">verderer-attested</span>
              : <span class="badge un">unverified</span>}
            <a class="url" href={r.url}>{r.url}</a>
          </div>
          <div class="meta">
            {r.attested && r.verderer?.bundle && (
              <span><a href={`/${r.verderer.bundle}`} download>download proof bundle ↓</a> · <a href="/verify">verify it →</a> · </span>
            )}
            {(r.external ?? []).map((e: any) => (
              <span class="src">{e.source} ({e.captures.length}) {e.captures[0] && <a href={e.captures[0].archive_url}>latest capture</a>}</span>
            ))}
            {(r.external ?? []).length === 0 && <span class="muted">no third-party archive</span>}
          </div>
        </li>
      ))}
    </ul>
    <p id="no-results" class="muted" hidden>No resources match that filter.</p>
  </section>

  <style>
    #search { width: 100%; margin: 4px 0 14px; padding: 9px 12px; border-radius: 8px;
      border: 1px solid var(--line); background: #0b0e12; color: var(--ink); font: inherit; }
    #search:focus { outline: none; border-color: var(--accent); }
    ul.resources { list-style: none; padding: 0; margin: 0; }
    ul.resources > li { padding: 12px 0; border-bottom: 1px solid var(--line); }
    .row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
    .badge { font-size: 12px; font-weight: 600; padding: 2px 8px; border-radius: 999px; }
    .badge.att { background: #123; color: #7fdca0; border: 1px solid #2a6; }
    .badge.un { background: #1a1d22; color: var(--low); border: 1px solid var(--line); }
    .url { word-break: break-all; }
    .meta { margin-top: 5px; font-size: 13px; color: var(--muted); }
    .meta .src { margin-right: 10px; }
  </style>

  <script is:inline>
    (() => {
      const input = document.getElementById('search');
      if (!input) return;
      const items = Array.from(document.querySelectorAll('ul.resources > li'));
      const none = document.getElementById('no-results');
      input.addEventListener('input', () => {
        const q = input.value.trim().toLowerCase();
        let shown = 0;
        for (const li of items) {
          const hit = !q || (li.dataset.search || '').includes(q);
          li.hidden = !hit;
          if (hit) shown++;
        }
        if (none) none.hidden = shown > 0;
      });
    })();
  </script>
</Base>
