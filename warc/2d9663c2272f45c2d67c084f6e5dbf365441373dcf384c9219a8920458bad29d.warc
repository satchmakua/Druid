          <div class="usa-card__media">
        <div class="usa-card__img">

  
    <img loading="eager" srcset="/system/files/styles/gallery_small/private/images/2023-10/map_0.png?h=58727e0f&amp;itok=ch471DiL 320w, /system/files/styles/gallery_medium/private/images/2023-10/map_0.png?h=58727e0f&amp;itok=cLXLSM35 640w" sizes="(max-width: 640px) calc(100vw - 2rem), 640px" width="640" height="360" src="/system/files/styles/gallery_medium/private/images/2023-10/map_0.png?h=58727e0f&amp;itok=cLXLSM35" alt="GHGRP RY2022 graduated symbol map of reporting facilities by emissions" />





