	<thead>
		<tr>
			<th>Contaminant</th>
			<th><abbr title="Maximum Contaminant Level Goal">MCLG</abbr><a href="#one"><sup>1</sup></a> (<abbr title="Milligrams per Liter">mg/L</abbr>)<a href="#two"><sup>2</sup></a></th>
