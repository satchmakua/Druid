# --- Base ignores (stack-agnostic) ---
# The scaffold skill appends a stack-specific block below this line.

# Secrets / local env — never commit real ones (see .env.example)
.env
.env.*
!.env.example
*.local

# AI assistant build instructions — kept local, never committed
CLAUDE.md
CLAUDE.local.md

# Editor / OS cruft
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
.idea/
.DS_Store
Thumbs.db
*.log

# Generic build / cache output
dist/
build/
out/
coverage/
.cache/
tmp/
*.tmp

# --- Stack-specific (appended by /scaffold) ---

# Python
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Druid runtime state — blobs, ledger, and the (local, M0) signing key. Never commit.
druid-data/
